<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.canvas.Canvas?>
<?import javafx.scene.chart.PieChart?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ListCell?>
<?import javafx.scene.control.ListView?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.RowConstraints?>
<?import javafx.scene.layout.VBox?>

<!--
    global-view.fxml — Dashboard global de la empresa
    CSS externo: trading-theme.css
    Estructura: GridPane 3 columnas x 3 filas (respeta original)
    Fondo: #121018 | Acento: #6C63FF | Verde: #00D09C
-->
<AnchorPane
        prefHeight="900.0"
        prefWidth="1900.0"
        stylesheets="@trading-theme.css"
        xmlns="http://javafx.com/javafx/17"
        xmlns:fx="http://javafx.com/fxml/1"
        fx:controller="org.example.paneljavafx.controller.GlobalController">

   <children>

      <GridPane
              styleClass="global-grid"
              AnchorPane.topAnchor="12.0"
              AnchorPane.bottomAnchor="12.0"
              AnchorPane.leftAnchor="12.0"
              AnchorPane.rightAnchor="12.0">

         <columnConstraints>
            <!-- Col 0: gráfico de línea + top fondos/activos -->
            <ColumnConstraints percentWidth="55"/>
            <!-- Col 1: gráfico circular + barra -->
            <ColumnConstraints percentWidth="24"/>
            <!-- Col 2: search panel (rowSpan 3) -->
            <ColumnConstraints percentWidth="21"/>
         </columnConstraints>

         <rowConstraints>
            <!-- Fila 0: KPI strip -->
            <RowConstraints prefHeight="100" minHeight="80" vgrow="NEVER"/>
            <!-- Fila 1: gráficos principales -->
            <RowConstraints vgrow="ALWAYS"/>
            <!-- Fila 2: top fondos / activos / barra -->
            <RowConstraints vgrow="ALWAYS"/>
         </rowConstraints>

         <children>

            <!-- ══════════════════════════════════════════════
                 FILA 0 — KPI STRIP (col 0+1, rowIndex 0)
            ═══════════════════════════════════════════════ -->
            <HBox styleClass="kpi-strip"
                  GridPane.columnIndex="0"
                  GridPane.columnSpan="2"
                  GridPane.rowIndex="0">

               <!-- Capital Total -->
               <VBox styleClass="kpi-block" HBox.hgrow="ALWAYS">
                  <children>
                     <Label text="CAPITAL TOTAL" styleClass="kpi-label"/>
                     <Label fx:id="kpiCapitalTotal" text="—" styleClass="kpi-value"/>
                     <Label fx:id="kpiCapitalDelta" text="+0,00%" styleClass="kpi-delta-positive"/>
                  </children>
               </VBox>

               <!-- Rentabilidad -->
               <VBox styleClass="kpi-block" HBox.hgrow="ALWAYS">
                  <children>
                     <Label text="RENTABILIDAD" styleClass="kpi-label"/>
                     <Label fx:id="kpiRentabilidad" text="—" styleClass="kpi-value"/>
                     <Label fx:id="kpiRentabilidadDelta" text="+0,00%" styleClass="kpi-delta-positive"/>
                  </children>
               </VBox>

               <!-- Total Fondos -->
               <VBox styleClass="kpi-block" HBox.hgrow="ALWAYS">
                  <children>
                     <Label text="VALOR FONDOS" styleClass="kpi-label"/>
                     <Label fx:id="kpiFondos" text="—" styleClass="kpi-value"/>
                     <Label fx:id="kpiFondosDelta" text="+0,00%" styleClass="kpi-delta-positive"/>
                  </children>
               </VBox>

               <!-- Total Assets -->
               <VBox styleClass="kpi-block" HBox.hgrow="ALWAYS">
                  <children>
                     <Label text="VALOR ACTIVOS" styleClass="kpi-label"/>
                     <Label fx:id="kpiActivos" text="—" styleClass="kpi-value"/>
                     <Label fx:id="kpiActivosDelta" text="+0,00%" styleClass="kpi-delta-positive"/>
                  </children>
               </VBox>

               <!-- Flujo Neto -->
               <VBox styleClass="kpi-block" HBox.hgrow="ALWAYS">
                  <children>
                     <Label text="FLUJO NETO MENSUAL" styleClass="kpi-label"/>
                     <Label fx:id="kpiFlujo" text="—" styleClass="kpi-value"/>
                     <Label fx:id="kpiFlujoBar" text="—" styleClass="kpi-delta-positive"/>
                  </children>
               </VBox>

            </HBox>

            <!-- ══════════════════════════════════════════════
                 FILA 1 COL 0 — GRÁFICO EVOLUCIÓN TOTAL
            ═══════════════════════════════════════════════ -->
            <VBox styleClass="card"
                  GridPane.columnIndex="0"
                  GridPane.rowIndex="1"
                  spacing="10.0">
               <GridPane.margin><Insets top="6"/></GridPane.margin>
               <children>
                  <Label text="EVOLUCIÓN CARTERA TOTAL" styleClass="card-title"/>
                  <Canvas fx:id="globalChartCanvas" height="220" VBox.vgrow="ALWAYS"/>
               </children>
            </VBox>

            <!-- ══════════════════════════════════════════════
                 FILA 1 COL 1 — PIE CHART % POR FONDO
            ═══════════════════════════════════════════════ -->
            <VBox styleClass="card"
                  GridPane.columnIndex="1"
                  GridPane.rowIndex="1"
                  spacing="10.0">
               <GridPane.margin><Insets top="6" left="6"/></GridPane.margin>
               <children>
                  <Label text="DISTRIBUCIÓN POR FONDO" styleClass="card-title"/>
                  <PieChart fx:id="globalPieChart"
                            styleClass="fund-pie-chart"
                            legendVisible="true"
                            legendSide="BOTTOM"
                            labelsVisible="false"
                            VBox.vgrow="ALWAYS"
                            prefHeight="220"/>
               </children>
            </VBox>

            <!-- ══════════════════════════════════════════════
                 FILA 2 COL 0 — TOP FONDOS + TOP ACTIVOS
            ═══════════════════════════════════════════════ -->
            <HBox spacing="12.0"
                  GridPane.columnIndex="0"
                  GridPane.rowIndex="2">
               <GridPane.margin><Insets top="6"/></GridPane.margin>

               <!-- Top Fondos -->
               <VBox styleClass="card" HBox.hgrow="ALWAYS" spacing="10.0">
                  <children>
                     <HBox alignment="CENTER_LEFT" spacing="10.0">
                        <children>
                           <Label text="FONDOS" styleClass="card-title" HBox.hgrow="ALWAYS"/>
                           <Label text="NAV TOTAL:" styleClass="kpi-label"/>
                           <Label fx:id="navTotalLabel" text="—" styleClass="fund-change-positive"/>
                        </children>
                     </HBox>
                     <TableView fx:id="topFondsTable"
                                styleClass="top-table"
                                VBox.vgrow="ALWAYS">
                        <columns>
                           <TableColumn fx:id="colFondoNombre" text="Fondo"/>
                           <TableColumn fx:id="colFondoValor"  text="NAV" prefWidth="110"/>
                        </columns>
                     </TableView>
                  </children>
               </VBox>

               <!-- Top Activos -->
               <VBox styleClass="card" HBox.hgrow="ALWAYS" spacing="10.0">
                  <children>
                     <Label text="TOP ACTIVOS" styleClass="card-title"/>
                     <TableView fx:id="topAssetsGlobalTable"
                                styleClass="top-table"
                                VBox.vgrow="ALWAYS">
                        <columns>
                           <TableColumn fx:id="colAssetNombre" text="Activo"/>
                           <TableColumn fx:id="colAssetPrecio" text="Precio"  prefWidth="90"/>
                           <TableColumn fx:id="colAssetCambio" text="Cambio"  prefWidth="80"/>
                        </columns>
                     </TableView>
                  </children>
               </VBox>

            </HBox>

            <!-- ══════════════════════════════════════════════
                 FILA 2 COL 1 — RENTABILIDAD MENSUAL
            ═══════════════════════════════════════════════ -->
            <VBox styleClass="card"
                  GridPane.columnIndex="1"
                  GridPane.rowIndex="2"
                  spacing="10.0">
               <GridPane.margin><Insets top="6" left="6"/></GridPane.margin>
               <children>
                  <Label text="RENTABILIDAD MENSUAL" styleClass="card-title"/>
                  <Canvas fx:id="barChartCanvas" VBox.vgrow="ALWAYS" height="200"/>
               </children>
            </VBox>

            <!-- ══════════════════════════════════════════════
                 COL 2 ROWS 0-2 — SEARCH PANEL
            ═══════════════════════════════════════════════ -->
            <VBox styleClass="search-panel"
                  GridPane.columnIndex="2"
                  GridPane.rowIndex="0"
                  GridPane.rowSpan="3">
               <GridPane.margin><Insets left="6"/></GridPane.margin>
               <children>

                  <Label text="BUSCAR" styleClass="kpi-label"/>

                  <TextField fx:id="searchField"
                             styleClass="search-field"
                             promptText="Fondo, activo, ticker, ISIN..."/>

                  <Label text="RESULTADOS" styleClass="kpi-label">
                     <VBox.margin><Insets top="8"/></VBox.margin>
                  </Label>

                  <ListView fx:id="resultsList"
                            styleClass="search-results"
                            VBox.vgrow="ALWAYS"/>

               </children>
            </VBox>

         </children>
      </GridPane>

   </children>
</AnchorPane>
