<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.canvas.Canvas?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.RowConstraints?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="900" prefWidth="1900.0" style="-fx-background-color: #121018;" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="org.example.paneljavafx.controller.AssetViewController">

    <children>
        <GridPane prefHeight="900.0" prefWidth="1900.0" AnchorPane.bottomAnchor="10.0" AnchorPane.leftAnchor="10.0" AnchorPane.rightAnchor="10.0" AnchorPane.topAnchor="10.0">

            <columnConstraints>
                <ColumnConstraints hgrow="ALWAYS" minWidth="200" />
                <ColumnConstraints hgrow="ALWAYS" minWidth="200" />
                <ColumnConstraints hgrow="ALWAYS" minWidth="200" />
            </columnConstraints>

            <rowConstraints>
                <RowConstraints vgrow="SOMETIMES" />
                <RowConstraints vgrow="SOMETIMES" />
                <RowConstraints vgrow="SOMETIMES" />
                <RowConstraints vgrow="SOMETIMES" />
            </rowConstraints>

            <!-- ================= CHART ================= -->
            <AnchorPane style="-fx-border-color: cyan; -fx-border-radius: 10;" GridPane.columnSpan="2" GridPane.rowIndex="1" GridPane.rowSpan="2">

                <children>

                    <Canvas fx:id="chartCanvas" height="604.0" layoutX="3.0" layoutY="3.0" width="1483.0" AnchorPane.bottomAnchor="1.0" AnchorPane.leftAnchor="1.0" AnchorPane.rightAnchor="1.0" AnchorPane.topAnchor="1.0" />

                </children>
            <GridPane.margin>
               <Insets bottom="10.0" left="10.0" right="10.0" top="10.0" />
            </GridPane.margin>

            </AnchorPane>

            <!-- ================= HEADER ================= -->
            <AnchorPane style="-fx-border-color: cyan; -fx-border-radius: 10;" GridPane.columnSpan="2">
                <children>
                    <Label fx:id="assetName" layoutX="46.0" layoutY="27.0" text="NOMBRE ACTIVO" textFill="AQUA">
                        <font>
                            <Font size="48" />
                        </font>
                    </Label>
                </children>

                <GridPane.margin>
                    <Insets bottom="10" left="10" right="10" top="10" />
                </GridPane.margin>
            </AnchorPane>

            <!-- ================= INFO ================= -->
            <AnchorPane style="-fx-border-color: cyan; -fx-border-radius: 10;" GridPane.columnIndex="2" GridPane.rowIndex="1">
                <children>


                    <Label fx:id="assetTicker" layoutX="20" layoutY="50" text="TICKER" textFill="AQUA" />

                    <Label fx:id="assetIsin" layoutX="20" layoutY="80" text="ISIN" textFill="AQUA" />

                    <Label fx:id="assetType" layoutX="20" layoutY="110" text="TYPE" textFill="AQUA" />

                    <Label fx:id="assetSector" layoutX="20" layoutY="140" text="SECTOR" textFill="AQUA" />

                    <Label fx:id="assetRisk" layoutX="20" layoutY="170" text="RISK" textFill="AQUA" />

                    <Label fx:id="assetLiquidity" layoutX="20" layoutY="200" text="LIQUIDITY" textFill="AQUA" />

                    <Label fx:id="assetPrice" layoutX="20" layoutY="230" text="PRICE" textFill="AQUA" />

                </children>

                <GridPane.margin>
                    <Insets bottom="10" left="10" right="10" top="10" />
                </GridPane.margin>
            </AnchorPane>

            <!-- ================= METRICS ================= -->
            <AnchorPane style="-fx-border-color: cyan; -fx-border-radius: 10;" GridPane.columnIndex="2" GridPane.rowIndex="2">
                <children>
                    <Label layoutX="40" layoutY="40" text="METRICAS" textFill="AQUA">
                        <font>
                            <Font size="30" />
                        </font>
                    </Label>

                    <Label fx:id="volatilityLabel" layoutX="40" layoutY="90" textFill="AQUA" />

                    <Label fx:id="marketCapLabel" layoutX="40" layoutY="130" textFill="AQUA" />

                    <Label fx:id="liquidityLabel" layoutX="40" layoutY="170" textFill="AQUA" />
                </children>

                <GridPane.margin>
                    <Insets bottom="10" left="10" right="10" top="10" />
                </GridPane.margin>
            </AnchorPane>

            <!-- ================= PIE CHART ================= -->
            <AnchorPane style="-fx-border-color: cyan; -fx-border-radius: 10;" GridPane.rowIndex="3">
                <children>
                    <Label layoutX="50" layoutY="80" text="GRAFICO CIRCULAR" textFill="AQUA">
                        <font>
                            <Font size="30" />
                        </font>
                    </Label>
                </children>

                <GridPane.margin>
                    <Insets bottom="10" left="10" right="10" top="10" />
                </GridPane.margin>
            </AnchorPane>

            <!-- ================= DESCRIPTION ================= -->
            <AnchorPane style="-fx-border-color: cyan; -fx-border-radius: 10;" GridPane.columnIndex="2" GridPane.rowIndex="3">
                <children>
                    <Label layoutX="40" layoutY="40" text="DESCRIPCION" textFill="AQUA">
                        <font>
                            <Font size="30" />
                        </font>
                    </Label>

                    <Label fx:id="descriptionLabel" layoutX="40" layoutY="100" prefWidth="300" textFill="AQUA" wrapText="true" />
                </children>

                <GridPane.margin>
                    <Insets bottom="10" left="10" right="10" top="10" />
                </GridPane.margin>
            </AnchorPane>

            <!-- ================= TABLE ================= -->
            <AnchorPane style="-fx-border-color: cyan; -fx-border-radius: 10;" GridPane.columnIndex="1" GridPane.rowIndex="3">
                <children>
                    <Label layoutX="40" layoutY="40" text="TABLA PORCENTAJES" textFill="AQUA">
                        <font>
                            <Font size="30" />
                        </font>
                    </Label>
                </children>

                <GridPane.margin>
                    <Insets bottom="10" left="10" right="10" top="10" />
                </GridPane.margin>
            </AnchorPane>

        </GridPane>
    </children>
</AnchorPane>
