<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.canvas.Canvas?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.RowConstraints?>
<?import javafx.scene.layout.VBox?>

<AnchorPane prefHeight="800.0" prefWidth="1900.0" style="-fx-background-color: #121018;" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="org.example.paneljavafx.controller.AssetViewController">

    <children>

        <GridPane hgap="15" layoutX="7.0" layoutY="2.0" vgap="15" AnchorPane.bottomAnchor="18.0" AnchorPane.leftAnchor="7.0" AnchorPane.rightAnchor="13.0" AnchorPane.topAnchor="2.0">

            <padding>
                <Insets bottom="15" left="15" right="15" top="15" />
            </padding>

            <!-- ================= ROWS ================= -->
            <rowConstraints>
                <RowConstraints maxHeight="436.0" minHeight="348.0" prefHeight="348.0" vgrow="ALWAYS" />
            <RowConstraints maxHeight="132.0" minHeight="10.0" prefHeight="132.0" vgrow="ALWAYS" />
                <RowConstraints maxHeight="140.0" minHeight="140.0" prefHeight="140.0" />
            </rowConstraints>

            <columnConstraints>
                <ColumnConstraints hgrow="ALWAYS" maxWidth="1424.3333740234375" minWidth="1371.0" prefWidth="1381.6666259765625" />
            <ColumnConstraints hgrow="ALWAYS" maxWidth="464.0" minWidth="10.0" prefWidth="453.3333740234375" />
            </columnConstraints>

            <!-- ================= TOP SECTION ================= -->
            <VBox spacing="10" style="-fx-background-color: #121018; -fx-text-fill: white; -fx-padding: 12; -fx-background-radius: 10;" GridPane.rowIndex="0" GridPane.rowSpan="3">

                <!-- HEADER -->
                <HBox spacing="15">

                    <VBox spacing="5">
                        <Label fx:id="assetName" style="-fx-text-fill: #fff; -fx-font-size: 20px; -fx-font-weight: bold;" text="Asset Name" />

                        <Label fx:id="assetTicker" style="-fx-text-fill: #fff;" text="TICKER" />
                    </VBox>

                    <Region HBox.hgrow="ALWAYS" />

                    <VBox alignment="CENTER_RIGHT" spacing="5">
                        <Label fx:id="assetPrice" style="-fx-text-fill: #fff; -fx-font-size: 22px; -fx-font-weight: bold;" text="0.00 €" />

                        <Label fx:id="assetChange" style="-fx-text-fill: #fff;" text="+0.00%" />
                    </VBox>

                </HBox>

                <!-- CHART -->
                <Canvas fx:id="chartCanvas" height="647.0" style="-fx-font-weight: 700; -fx-text-fill: white;" width="1357.0" />
            </VBox>

             <!-- RISK -->
             <GridPane hgap="10" prefHeight="136.0" prefWidth="454.0" style="-fx-background-color: #1e1e1e; -fx-text-fill: white; -fx-padding: 15; -fx-background-radius: 10;" vgap="10" GridPane.columnIndex="1" GridPane.rowIndex="2">

                 <columnConstraints>
                     <ColumnConstraints hgrow="ALWAYS" maxWidth="123.0" minWidth="61.0" prefWidth="71.0" />
               <ColumnConstraints hgrow="ALWAYS" maxWidth="180.0" minWidth="80.0" prefWidth="180.0" />
                     <ColumnConstraints hgrow="ALWAYS" maxWidth="114.0" minWidth="53.0" prefWidth="70.0" />
               <ColumnConstraints hgrow="ALWAYS" maxWidth="113.0" minWidth="10.0" prefWidth="68.0" />
                 </columnConstraints>

                 <rowConstraints>
                     <RowConstraints vgrow="ALWAYS" />
                     <RowConstraints vgrow="ALWAYS" />
               <RowConstraints vgrow="ALWAYS" />
                 </rowConstraints>

                 <!-- Row 0 -->
                 <Label style="-fx-font-weight: 700; -fx-text-fill: white;" text="Risk:" GridPane.columnIndex="2" />
                 <Label fx:id="assetRisk" prefHeight="17.0" prefWidth="164.0" style="-fx-font-weight: 700; -fx-text-fill: white;" GridPane.columnIndex="3" />

                 <!-- Row 2 -->
                 <Label style="-fx-font-weight: 700; -fx-text-fill: white;" text="Volatility:" GridPane.columnIndex="2" GridPane.rowIndex="2" />
                 <Label fx:id="assetVolatility" prefHeight="17.0" prefWidth="133.0" style="-fx-font-weight: 700; -fx-text-fill: white;" GridPane.columnIndex="3" GridPane.rowIndex="2" />
                 <!-- Row 1 -->
                 <Label style="-fx-font-weight: 700; -fx-text-fill: white;" text="Liquidity:" GridPane.columnIndex="2" GridPane.rowIndex="1" />
                 <Label fx:id="assetLiquidity" prefHeight="17.0" prefWidth="170.0" style="-fx-font-weight: 700; -fx-text-fill: white;" GridPane.columnIndex="3" GridPane.rowIndex="1" />

                 <Label style="-fx-font-weight: 700; -fx-text-fill: white;" text="Market Cap:" />
                 <Label fx:id="assetMarketCap" prefHeight="17.0" prefWidth="246.0" style="-fx-font-weight: 700; -fx-text-fill: white;" GridPane.columnIndex="1" />

                 <!-- ROW 1 -->
                 <Label style="-fx-font-weight: 700; -fx-text-fill: white;" text="Type:" GridPane.rowIndex="1" />
                 <Label fx:id="assetType" prefHeight="17.0" prefWidth="151.0" style="-fx-font-weight: 700; -fx-text-fill: white;" GridPane.columnIndex="1" GridPane.rowIndex="1" />

                 <!-- ROW 2 -->
                 <Label style="-fx-font-weight: 700; -fx-text-fill: white;" text="Sector:" GridPane.rowIndex="2" />
                 <Label fx:id="assetSector" prefHeight="17.0" prefWidth="90.0" style="-fx-font-weight: 700; -fx-text-fill: white;" GridPane.columnIndex="1" GridPane.rowIndex="2" />

             </GridPane>

            <TableView fx:id="tabla_exposicion" prefHeight="200.0" prefWidth="441.0" style="-fx-background-color: #1e1e1e; -fx-font-size: 16px;" GridPane.columnIndex="1" GridPane.rowIndex="1">

                <columns>
                    <TableColumn fx:id="colFund" prefWidth="300" text="Fondo" style="-fx-font-weight: 700;" />
                    <TableColumn fx:id="colValue" prefWidth="152.0" text="Valor" style="-fx-font-weight: 700;" />
                </columns>

            </TableView>
         <VBox fx:id="assetPieChart" prefHeight="200.0" prefWidth="100.0" GridPane.columnIndex="1" />

        </GridPane>

    </children>
</AnchorPane>
