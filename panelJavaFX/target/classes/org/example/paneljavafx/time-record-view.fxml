<?xml version="1.0" encoding="UTF-8"?>

<?import java.lang.*?>
<?import java.util.*?>
<?import javafx.scene.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="org.example.paneljavafx.controller.TimeRecordPanelController"
      spacing="10"
      alignment="CENTER"
      style="
        -fx-background-color: rgba(255,255,255,0.60);
        -fx-background-radius: 20;
        -fx-border-radius: 20;
        -fx-border-color: rgba(255,255,255,0.6);
        -fx-border-width: 1;
        -fx-padding: 20;
        -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.25), 20, 0.3, 0, 4);
      ">

    <HBox spacing="10" alignment="CENTER_LEFT" maxWidth="Infinity" HBox.hgrow="ALWAYS">
        <Label fx:id="lbl2Message"
               style="-fx-font-size: 15px; -fx-font-weight: bold;"
               maxWidth="Infinity"
               HBox.hgrow="ALWAYS"/>
        <Label fx:id="lblMessage"
               style="-fx-font-size: 15px; -fx-font-weight: bold;"/>
    </HBox>

    <HBox spacing="10" alignment="CENTER">
        <Button fx:id="btnCheckIn" text="Check In" onAction="#handleCheckIn"/>
        <Button fx:id="btnCheckOut" text="Check Out" onAction="#handleCheckOut"/>
    </HBox>

    <Label text="Time Records"
           style="-fx-font-size: 18px; -fx-font-weight: bold;" />

    <TableView fx:id="timeRecordsTable"
               VBox.vgrow="ALWAYS"
               maxHeight="350"
               style="-fx-background-radius: 10;">
        <columns>
            <TableColumn fx:id="colCode" text="Code" prefWidth="60"  maxWidth="1E7"/>
            <TableColumn fx:id="colDateTime" text="Date &amp; Time" prefWidth="200"  maxWidth="1E7"/>
            <TableColumn fx:id="colType" text="Type" prefWidth="80"  maxWidth="1E7"/>
        </columns>
    </TableView>
</VBox>
