<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Tab?>
<?import javafx.scene.control.TabPane?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.RowConstraints?>

<!--
    admin-view.fxml — Panel de administración principal
    CSS externo: trading-theme.css
    Estructura respetada: GridPane 1col × 2row → header + TabPane
-->
<AnchorPane
        prefHeight="1000.0"
        prefWidth="1800.0"
        stylesheets="@trading-theme.css"
        xmlns="http://javafx.com/javafx/17"
        xmlns:fx="http://javafx.com/fxml/1"
        fx:controller="org.example.paneljavafx.controller.AdminViewController">

    <children>

        <GridPane
                AnchorPane.topAnchor="0"
                AnchorPane.bottomAnchor="0"
                AnchorPane.leftAnchor="0"
                AnchorPane.rightAnchor="0">

            <columnConstraints>
                <ColumnConstraints hgrow="ALWAYS"/>
            </columnConstraints>

            <rowConstraints>
                <!-- Fila 0: header fijo -->
                <RowConstraints prefHeight="56" minHeight="56" vgrow="NEVER"/>
                <!-- Fila 1: contenido -->
                <RowConstraints vgrow="ALWAYS"/>
            </rowConstraints>

            <!-- ══════════════════════════════════════════════
                 HEADER
            ═══════════════════════════════════════════════ -->
            <HBox styleClass="admin-header"
                  GridPane.rowIndex="0">

                <!-- Logo / Brand -->
                <Label styleClass="admin-brand">
                    <text>STOCK<Label styleClass="admin-brand-accent" text="MASTER"/></text>
                </Label>

                <!-- Separador flexible -->
                <Region HBox.hgrow="ALWAYS"/>

                <!-- Botón perfil -->
                <Button styleClass="admin-btn" text="PERFIL"/>

            </HBox>

            <!-- ══════════════════════════════════════════════
                 TABPANE PRINCIPAL
            ═══════════════════════════════════════════════ -->
            <TabPane fx:id="tabPane"
                     styleClass="admin-tabpane"
                     maxHeight="Infinity"
                     maxWidth="Infinity"
                     GridPane.rowIndex="1">

                <tabs>

                    <!-- POSICIÓN GLOBAL -->
                    <Tab fx:id="searchTab"
                         text="Posición"
                         closable="false">
                        <fx:include source="global-view.fxml"/>
                    </Tab>

                    <!-- FONDOS (TabPane interno) -->
                    <Tab fx:id="fundTab"
                         text="Fondos"
                         closable="false">
                        <content>
                            <AnchorPane>
                                <children>
                                    <TabPane fx:id="fundTabPane"
                                             styleClass="inner-tabpane"
                                             tabClosingPolicy="ALL_TABS"
                                             AnchorPane.topAnchor="0"
                                             AnchorPane.bottomAnchor="0"
                                             AnchorPane.leftAnchor="0"
                                             AnchorPane.rightAnchor="0"/>
                                </children>
                            </AnchorPane>
                        </content>
                    </Tab>

                    <!-- ACTIVOS (TabPane interno) -->
                    <Tab fx:id="assetTab"
                         text="Activos"
                         closable="false">
                        <content>
                            <AnchorPane>
                                <children>
                                    <TabPane fx:id="assetTabPane"
                                             styleClass="inner-tabpane"
                                             tabClosingPolicy="ALL_TABS"
                                             AnchorPane.topAnchor="0"
                                             AnchorPane.bottomAnchor="0"
                                             AnchorPane.leftAnchor="0"
                                             AnchorPane.rightAnchor="0"/>
                                </children>
                            </AnchorPane>
                        </content>
                    </Tab>

                    <!-- PERSONAL -->
                    <Tab fx:id="personalTab"
                         text="Personal"
                         closable="false">
                        <fx:include source="personal-view.fxml"/>
                    </Tab>

                    <!-- CLIENTES -->
                    <Tab fx:id="clienteTab"
                         text="Clientes"
                         closable="false">
                        <fx:include source="clientesGestion-view.fxml"/>
                    </Tab>

                </tabs>

            </TabPane>

        </GridPane>

    </children>
</AnchorPane>
