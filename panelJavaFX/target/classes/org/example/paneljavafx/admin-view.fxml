<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Tab?>
<?import javafx.scene.control.TabPane?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.VBox?>

<AnchorPane
        prefHeight="1000.0"
        prefWidth="1800.0"
        stylesheets="@trading-theme.css"
        xmlns="http://javafx.com/javafx/17"
        xmlns:fx="http://javafx.com/fxml/1"
        fx:controller="org.example.paneljavafx.controller.AdminViewController">

    <children>

        <TabPane fx:id="tabPane"
                 styleClass="admin-tabpane"
                 tabClosingPolicy="UNAVAILABLE"
                 AnchorPane.topAnchor="0"
                 AnchorPane.bottomAnchor="0"
                 AnchorPane.leftAnchor="0"
                 AnchorPane.rightAnchor="0">

            <tabs>

                <Tab fx:id="searchTab" text="Posición" closable="false">
                    <fx:include source="global-view.fxml"/>
                </Tab>

                <Tab fx:id="fundTab" text="Fondos" closable="false">
                    <content>
                        <AnchorPane>
                            <TabPane fx:id="fundTabPane"
                                     styleClass="inner-tabpane"
                                     tabClosingPolicy="ALL_TABS"
                                     AnchorPane.topAnchor="0"
                                     AnchorPane.bottomAnchor="0"
                                     AnchorPane.leftAnchor="0"
                                     AnchorPane.rightAnchor="0">
                                <tabs>
                                    <Tab text="" closable="false">
                                        <content>
                                            <AnchorPane styleClass="empty-tab-pane">
                                                <VBox alignment="CENTER"
                                                      AnchorPane.topAnchor="0"
                                                      AnchorPane.bottomAnchor="0"
                                                      AnchorPane.leftAnchor="0"
                                                      AnchorPane.rightAnchor="0">
                                                    <Label text="📊" styleClass="cliente-empty-icon"/>
                                                    <Label text="Selecciona un fondo para abrirlo"
                                                           styleClass="cliente-empty-text"/>
                                                </VBox>
                                            </AnchorPane>
                                        </content>
                                    </Tab>
                                </tabs>
                            </TabPane>
                        </AnchorPane>
                    </content>
                </Tab>

                <Tab fx:id="assetTab" text="Activos" closable="false">
                    <content>
                        <AnchorPane>
                            <TabPane fx:id="assetTabPane"
                                     styleClass="inner-tabpane"
                                     tabClosingPolicy="ALL_TABS"
                                     AnchorPane.topAnchor="0"
                                     AnchorPane.bottomAnchor="0"
                                     AnchorPane.leftAnchor="0"
                                     AnchorPane.rightAnchor="0">
                                <tabs>
                                    <Tab text="" closable="false">
                                        <content>
                                            <AnchorPane styleClass="empty-tab-pane">
                                                <VBox alignment="CENTER"
                                                      AnchorPane.topAnchor="0"
                                                      AnchorPane.bottomAnchor="0"
                                                      AnchorPane.leftAnchor="0"
                                                      AnchorPane.rightAnchor="0">
                                                    <Label text="📈" styleClass="cliente-empty-icon"/>
                                                    <Label text="Selecciona un activo para abrirlo"
                                                           styleClass="cliente-empty-text"/>
                                                </VBox>
                                            </AnchorPane>
                                        </content>
                                    </Tab>
                                </tabs>
                            </TabPane>
                        </AnchorPane>
                    </content>
                </Tab>

                <Tab fx:id="personalTab" text="Personal" closable="false">
                    <fx:include source="personal-view.fxml"/>
                </Tab>

                <Tab fx:id="clienteTab" text="Clientes" closable="false">
                    <fx:include source="clientesGestion-view.fxml"/>
                </Tab>

            </tabs>

        </TabPane>

    </children>

</AnchorPane>