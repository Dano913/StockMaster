<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.canvas.Canvas?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ListView?>
<?import javafx.scene.control.ProgressBar?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.RowConstraints?>
<?import javafx.scene.layout.VBox?>

<AnchorPane xmlns="http://javafx.com/javafx/25"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="org.example.paneljavafx.controller.AssetViewController"
            style="-fx-background-color: #f4f4f4;"
            prefWidth="1000" prefHeight="700">

    <children>

        <GridPane hgap="15" vgap="15"
                  AnchorPane.topAnchor="10"
                  AnchorPane.bottomAnchor="10"
                  AnchorPane.leftAnchor="10"
                  AnchorPane.rightAnchor="10">

            <padding>
                <Insets top="15" right="15" bottom="15" left="15"/>
            </padding>

            <!-- ================= ROWS ================= -->
            <rowConstraints>
                <RowConstraints vgrow="ALWAYS"/>
                <RowConstraints prefHeight="140" minHeight="140" maxHeight="140"/>
            </rowConstraints>

            <columnConstraints>
                <ColumnConstraints hgrow="ALWAYS"/>
            </columnConstraints>

            <!-- ================= TOP SECTION ================= -->
            <VBox spacing="10"
                  style="-fx-background-color: white; -fx-padding: 12; -fx-background-radius: 10;"
                  GridPane.rowIndex="0">

                <!-- HEADER -->
                <HBox spacing="15">

                    <VBox spacing="5">
                        <Label fx:id="assetName"
                               style="-fx-font-size: 20px; -fx-font-weight: bold;"
                               text="Asset Name"/>

                        <Label fx:id="assetTicker"
                               style="-fx-text-fill: #666;"
                               text="TICKER"/>
                    </VBox>

                    <Region HBox.hgrow="ALWAYS"/>

                    <VBox alignment="CENTER_RIGHT" spacing="5">
                        <Label fx:id="assetPrice"
                               style="-fx-font-size: 22px; -fx-font-weight: bold;"
                               text="0.00 €"/>

                        <Label fx:id="assetChange"
                               text="+0.00%"/>
                    </VBox>

                </HBox>

                <!-- CHART -->
                <Canvas fx:id="chartCanvas"
                        width="900"
                        height="350"/>
            </VBox>

            <!-- ================= METRICS ================= -->
            <GridPane hgap="15"
                      GridPane.rowIndex="1">

                <columnConstraints>
                    <ColumnConstraints hgrow="ALWAYS"/>
                    <ColumnConstraints hgrow="ALWAYS"/>
                    <ColumnConstraints hgrow="ALWAYS"/>
                </columnConstraints>

                <!-- EXPOSURE -->
                <VBox spacing="8"
                      style="-fx-background-color: white; -fx-padding: 15; -fx-background-radius: 10;">

                    <Label text="EXPOSURE" style="-fx-text-fill: #888;"/>
                    <Label fx:id="assetFundsCount" text="0 funds"/>
                    <Label fx:id="assetWeight" text="0.00%"/>
                    <ProgressBar fx:id="assetExposure" progress="0.0"
                                 maxWidth="1.7976931348623157E308"/>
                </VBox>

                <!-- RISK -->
                <VBox spacing="8"
                      style="-fx-background-color: white; -fx-padding: 15; -fx-background-radius: 10;"
                      GridPane.columnIndex="1">

                    <Label text="RISK" style="-fx-text-fill: #888;"/>
                    <Label fx:id="assetRisk" text="Risk: -"/>
                    <Label fx:id="assetLiquidity" text="Liquidity: -"/>
                </VBox>

                <!-- TABLE -->
                <VBox spacing="10"
                      style="-fx-background-color: white; -fx-padding: 15; -fx-background-radius: 10;"
                      GridPane.columnIndex="2">

                    <Label text="Fund Exposure"
                           style="-fx-font-weight: bold;"/>

                    <ListView fx:id="tabla_exposicion"/>
                </VBox>

            </GridPane>

        </GridPane>

    </children>
</AnchorPane>