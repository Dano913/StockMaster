<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ListView?>
<?import javafx.scene.control.ProgressBar?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<AnchorPane prefHeight="600.0" prefWidth="800.0" style="-fx-background-color: #f4f4f4;" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="org.example.paneljavafx.controller.FundViewController">
    <children>
        <VBox spacing="20.0" AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">
            <padding>
                <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
            </padding>
            <children>
                <!-- Header Info -->
                <HBox spacing="30.0" style="-fx-background-color: white; -fx-padding: 20; -fx-background-radius: 10; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.1 ), 10, 0, 0, 0);">
                    <children>
                        <VBox spacing="5.0">
                            <children>
                                <!-- CAMBIADO: fx:id="fundName" -->
                                <Label fx:id="fundName" style="-fx-font-size: 24px; -fx-font-weight: bold;" text="Nombre del Fondo" />
                                <HBox spacing="10.0">
                                    <children>
                                        <!-- CAMBIADO: fx:id="fundTicker" -->
                                        <Label fx:id="fundTicker" style="-fx-text-fill: #666;" text="TICKER" />
                                        <Label style="-fx-text-fill: #ccc;" text="|" />
                                        <!-- CAMBIADO: fx:id="fundIsin" -->
                                        <Label fx:id="fundIsin" style="-fx-text-fill: #666;" text="ISIN-00000000" />
                                    </children>
                                </HBox>
                            </children>
                        </VBox>
                        <VBox spacing="5.0">
                            <children>
                                <!-- CAMBIADO: fx:id="fundType" -->
                                <Label fx:id="fundType" style="-fx-background-color: #e1f5fe; -fx-text-fill: #01579b; -fx-padding: 5 10; -fx-background-radius: 5;" text="TIPO" />
                                <!-- CAMBIADO: fx:id="fundCategory" -->
                                <Label fx:id="fundCategory" style="-fx-text-fill: #888; -fx-font-size: 12px;" text="Categoría" />
                            </children>
                        </VBox>
                    </children>
                </HBox>

                <!-- Metrics Grid -->
                <HBox spacing="20.0">
                    <children>
                        <VBox spacing="10.0" style="-fx-background-color: white; -fx-padding: 20; -fx-background-radius: 10; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.05), 5, 0, 0, 0);" HBox.hgrow="ALWAYS">
                            <children>
                                <Label style="-fx-text-fill: #888;" text="VALOR LIQUIDATIVO" />
                                <!-- CAMBIADO: fx:id="fundValue" -->
                                <Label fx:id="fundValue" style="-fx-font-size: 28px; -fx-font-weight: bold;" text="0.00 €" />
                                <HBox spacing="10.0">
                                    <children>
                                        <!-- CAMBIADO: fx:id="fundChange" -->
                                        <Label fx:id="fundChange" style="-fx-font-weight: bold;" text="+0.00%" />
                                        <!-- CAMBIADO: fx:id="fundDailyReturn" -->
                                        <Label fx:id="fundDailyReturn" text="(+0 € hoy)" />
                                    </children>
                                </HBox>
                            </children>
                        </VBox>
                        <VBox spacing="10.0" style="-fx-background-color: white; -fx-padding: 20; -fx-background-radius: 10; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.05), 5, 0, 0, 0);" HBox.hgrow="ALWAYS">
                            <children>
                                <Label style="-fx-text-fill: #888;" text="ESTADÍSTICAS" />
                                <!-- CAMBIADO: fx:id="totalAUM" -->
                                <Label fx:id="totalAUM" style="-fx-font-size: 18px;" text="0.00 AUM" />
                                <!-- CAMBIADO: fx:id="exposureRisk" -->
                                <Label fx:id="exposureRisk" style="-fx-text-fill: #f44336;" text="Riesgo: 0/10" />
                                <ProgressBar fx:id="performanceBar" maxWidth="1.7976931348623157E308" progress="0.0" />
                            </children>
                        </VBox>
                    </children>
                </HBox>

                <!-- Top Assets -->
                <VBox spacing="10.0" style="-fx-background-color: white; -fx-padding: 20; -fx-background-radius: 10; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.05), 5, 0, 0, 0);" VBox.vgrow="ALWAYS">
                    <children>
                        <Label style="-fx-font-weight: bold; -fx-font-size: 16px;" text="Principales Posiciones e Impacto" />
                        <ListView fx:id="topAssetsList" VBox.vgrow="ALWAYS" />
                    </children>
                </VBox>
            </children>
        </VBox>
    </children>
</AnchorPane>
