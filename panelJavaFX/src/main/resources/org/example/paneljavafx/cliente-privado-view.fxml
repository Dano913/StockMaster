<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.chart.PieChart?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.RowConstraints?>
<?import javafx.scene.layout.VBox?>

<!--
    cliente-privado-view.fxml — Detalle del cliente privado
    CSS externo: trading-theme.css
    Estructura respetada: VBox → Header / HBox(datos+pie) / tabla
-->
<AnchorPane
        stylesheets="@trading-theme.css"
        xmlns="http://javafx.com/javafx/17"
        xmlns:fx="http://javafx.com/fxml/1"
        fx:controller="org.example.paneljavafx.controller.ClientePrivadoViewController">

    <children>

        <VBox spacing="16"
              AnchorPane.topAnchor="20"
              AnchorPane.bottomAnchor="20"
              AnchorPane.leftAnchor="20"
              AnchorPane.rightAnchor="20">

            <!-- ══════════════════════════════════════════
                 HEADER — Nombre y email
            ═══════════════════════════════════════════ -->
            <VBox spacing="4">
                <children>
                    <Label fx:id="labelNombre" styleClass="cp-nombre"/>
                    <Label fx:id="labelEmail"  styleClass="cp-email"/>
                </children>
            </VBox>

            <!-- ══════════════════════════════════════════
                 FILA CENTRAL — Datos + Pie chart
            ═══════════════════════════════════════════ -->
            <HBox spacing="16">
                <children>

                    <!-- DATOS DEL CLIENTE -->
                    <GridPane styleClass="cp-data-card"
                              hgap="16" vgap="0"
                              HBox.hgrow="ALWAYS">

                        <columnConstraints>
                            <ColumnConstraints percentWidth="25"/>
                            <ColumnConstraints percentWidth="25"/>
                            <ColumnConstraints percentWidth="25"/>
                            <ColumnConstraints percentWidth="25"/>
                        </columnConstraints>

                        <rowConstraints>
                            <RowConstraints prefHeight="68"/>
                            <RowConstraints prefHeight="68"/>
                            <RowConstraints prefHeight="68"/>
                            <RowConstraints prefHeight="68"/>
                        </rowConstraints>

                        <!-- ROW 0 — ID + DNI -->
                        <VBox spacing="4" GridPane.columnIndex="0" GridPane.rowIndex="0">
                            <Label text="ID CLIENTE" styleClass="cp-field-label"/>
                            <Label fx:id="labelIdCliente" styleClass="cp-field-value"/>
                        </VBox>

                        <VBox spacing="4" GridPane.columnIndex="1" GridPane.rowIndex="0">
                            <Label text="DNI" styleClass="cp-field-label"/>
                            <Label fx:id="labelDni" styleClass="cp-field-value"/>
                        </VBox>

                        <!-- ROW 1 — País + Fecha alta -->
                        <VBox spacing="4" GridPane.columnIndex="0" GridPane.rowIndex="1">
                            <Label text="PAÍS" styleClass="cp-field-label"/>
                            <Label fx:id="labelPais" styleClass="cp-field-value"/>
                        </VBox>

                        <VBox spacing="4" GridPane.columnIndex="1" GridPane.rowIndex="1">
                            <Label text="FECHA ALTA" styleClass="cp-field-label"/>
                            <Label fx:id="labelFechaAlta" styleClass="cp-field-value"/>
                        </VBox>

                        <!-- ROW 2 — Gestor + Valor cartera -->
                        <VBox spacing="4" GridPane.columnIndex="0" GridPane.rowIndex="2">
                            <Label text="GESTOR" styleClass="cp-field-label"/>
                            <Label fx:id="labelGestor" styleClass="cp-field-value"/>
                        </VBox>

                        <VBox spacing="4" GridPane.columnIndex="1" GridPane.rowIndex="2"
                              GridPane.columnSpan="2">
                            <Label text="VALOR CARTERA" styleClass="cp-field-label"/>
                            <Label fx:id="labelValorCartera" styleClass="cp-field-value-accent"/>
                        </VBox>

                        <!-- ROW 3 — Rentabilidad -->
                        <VBox spacing="4" GridPane.columnIndex="0" GridPane.rowIndex="3"
                              GridPane.columnSpan="2">
                            <Label text="RENTABILIDAD" styleClass="cp-field-label"/>
                            <Label fx:id="labelRentabilidad" styleClass="cp-field-value-positive"/>
                        </VBox>

                    </GridPane>

                    <!-- PIE CHART -->
                    <VBox styleClass="cp-pie-card" prefWidth="400">
                        <children>
                            <Label text="DISTRIBUCIÓN POR FONDOS" styleClass="cp-pie-title"/>
                            <PieChart fx:id="portfolioPieChart"
                                      styleClass="cp-pie-chart"
                                      labelsVisible="false"
                                      legendVisible="true"
                                      legendSide="BOTTOM"
                                      prefHeight="260"
                                      prefWidth="360"
                                      VBox.vgrow="ALWAYS"/>
                        </children>
                    </VBox>

                </children>
            </HBox>

            <!-- ══════════════════════════════════════════
                 TABLA — Inversiones / Transacciones
            ═══════════════════════════════════════════ -->
            <VBox styleClass="cp-data-card" VBox.vgrow="ALWAYS" spacing="12">
                <children>
                    <Label text="INVERSIONES" styleClass="cp-pie-title"/>
                    <TableView fx:id="inversionesTable"
                               styleClass="cp-table"
                               VBox.vgrow="ALWAYS">
                        <columnResizePolicy>
                            <TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/>
                        </columnResizePolicy>
                        <columns>
                            <TableColumn fx:id="colFund"            text="Fondo"/>
                            <TableColumn fx:id="colTypeTransaction"  text="Tipo"           prefWidth="100"/>
                            <TableColumn fx:id="colAmountTransaction" text="Importe"        prefWidth="130"/>
                            <TableColumn fx:id="colTotalPosition"   text="Total Posición"  prefWidth="150"/>
                        </columns>
                        <placeholder>
                            <Label text="Sin inversiones registradas" styleClass="cp-field-label"/>
                        </placeholder>
                    </TableView>
                </children>
            </VBox>

        </VBox>

    </children>
</AnchorPane>
