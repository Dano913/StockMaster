<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>

<AnchorPane prefHeight="900" prefWidth="1900.0"
            style="-fx-background-color: #121018;"
            xmlns="http://javafx.com/javafx/17"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="org.example.paneljavafx.controller.PersonalViewController">

   <children>
      <GridPane AnchorPane.topAnchor="0"
                AnchorPane.bottomAnchor="0"
                AnchorPane.leftAnchor="0"
                AnchorPane.rightAnchor="0"
                hgap="20"
                style="-fx-border-color: cyan; -fx-border-radius: 10;">

         <columnConstraints>
            <ColumnConstraints hgrow="ALWAYS" percentWidth="50"/>
            <ColumnConstraints hgrow="ALWAYS" percentWidth="50"/>
         </columnConstraints>

         <rowConstraints>
            <RowConstraints vgrow="ALWAYS"/>
         </rowConstraints>

         <!-- LEFT PANEL -->
         <VBox spacing="15" GridPane.columnIndex="0">

            <Label text="👤 Gestors"
                   style="-fx-font-size: 16px; -fx-font-weight: bold;"/>

            <TextField fx:id="searchField"
                       promptText="Search gestors..."/>

            <TableView fx:id="gestorsTable" VBox.vgrow="ALWAYS">

               <columns>
                  <TableColumn fx:id="colName" text="Name"/>
                  <TableColumn fx:id="colEmail" text="Email"/>

                  <!-- FIX IMPORTANTE -->
                  <TableColumn fx:id="colExperience" text="Experience"/>
                  <TableColumn fx:id="colRisk" text="Risk"/>
               </columns>

            </TableView>

         </VBox>

         <!-- RIGHT PANEL -->
         <VBox spacing="15" GridPane.columnIndex="1">

            <Label text="⏱ Time Records"
                   style="-fx-font-size: 16px; -fx-font-weight: bold;"/>

            <TableView fx:id="timeRecordsTable" VBox.vgrow="ALWAYS">

               <columns>
                  <TableColumn fx:id="colUser" text="User"/>
                  <TableColumn fx:id="colDateTime" text="Date"/>
                  <TableColumn fx:id="colType" text="Type"/>
               </columns>

            </TableView>

         </VBox>

      </GridPane>
   </children>

</AnchorPane>