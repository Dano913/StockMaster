<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<StackPane
        xmlns="http://javafx.com/javafx/17"
        xmlns:fx="http://javafx.com/fxml/1"
        fx:controller="org.example.paneljavafx.controller.PersonalViewController"
        prefHeight="900"
        prefWidth="1900"
        stylesheets="@trading-theme.css">

   <children>

      <!-- =========================
           MAIN LAYOUT
      ========================== -->
      <AnchorPane>

         <children>

            <GridPane
                    styleClass="cliente-grid"
                    hgap="16"
                    AnchorPane.topAnchor="0"
                    AnchorPane.bottomAnchor="0"
                    AnchorPane.leftAnchor="0"
                    AnchorPane.rightAnchor="0">

               <columnConstraints>
                  <ColumnConstraints hgrow="ALWAYS" percentWidth="50"/>
                  <ColumnConstraints hgrow="ALWAYS" percentWidth="50"/>
               </columnConstraints>

               <rowConstraints>
                  <RowConstraints vgrow="ALWAYS"/>
               </rowConstraints>

               <!-- ═══════════════════════════════
                    LEFT PANEL
               ════════════════════════════════ -->
               <VBox styleClass="cliente-left-panel"
                     GridPane.columnIndex="0"
                     GridPane.rowIndex="0">

                  <Label text="GESTORES"
                         styleClass="cliente-panel-title"/>

                  <Button text="➕ Añadir Gestor"
                          onAction="#openAddGestor"
                          styleClass="btn-primary"/>

                  <TextField fx:id="searchField"
                             styleClass="cliente-search"
                             promptText="Buscar gestor..."/>

                  <TableView fx:id="gestorsTable"
                             styleClass="cliente-table"
                             VBox.vgrow="ALWAYS">

                     <columnResizePolicy>
                        <TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/>
                     </columnResizePolicy>

                     <columns>

                        <TableColumn fx:id="colName"
                                     text="Nombre"
                                     prefWidth="220"/>

                        <TableColumn fx:id="colEmail"
                                     text="Email"
                                     prefWidth="200"/>

                        <TableColumn fx:id="colExperience"
                                     text="Exp"
                                     prefWidth="100"/>

                        <TableColumn fx:id="colRisk"
                                     text="Riesgo"
                                     prefWidth="100"/>

                        <!-- BOTÓN ACCIÓN (lo crea controller igual que cliente) -->
                        <TableColumn text="Acciones"
                                     prefWidth="120"/>

                     </columns>

                     <placeholder>
                        <Label text="Sin gestores"
                               styleClass="kpi-label"/>
                     </placeholder>

                  </TableView>

               </VBox>

               <!-- ═══════════════════════════════
                    RIGHT PANEL (detalle opcional)
               ════════════════════════════════ -->
               <VBox fx:id="gestorDetailContainer"
                     styleClass="cliente-right-panel"
                     GridPane.columnIndex="1"
                     GridPane.rowIndex="0">

                  <VBox styleClass="cliente-detail-empty"
                        alignment="CENTER"
                        VBox.vgrow="ALWAYS">

                     <Label text="👤"
                            styleClass="cliente-empty-icon"/>

                     <Label text="Selecciona un gestor o edítalo"
                            styleClass="cliente-empty-text"/>

                  </VBox>

               </VBox>

            </GridPane>

         </children>

      </AnchorPane>

      <!-- =========================
           OVERLAY MODAL (🔥 CLAVE)
      ========================== -->
      <VBox fx:id="overlayContainer"
            visible="false"
            managed="false"
            alignment="CENTER"
            StackPane.alignment="CENTER"
            style="-fx-background-color: rgba(0,0,0,0.45);">

         <!-- AQUÍ SE INYECTA EL FORMULARIO -->
      </VBox>

   </children>

</StackPane>