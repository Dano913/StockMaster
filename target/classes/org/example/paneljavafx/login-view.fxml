<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.Insets?>

<VBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="org.example.paneljavafx.controller.LoginController"
      alignment="CENTER"
      spacing="12"
      prefWidth="400"
      prefHeight="360"
      maxWidth="400"
      styleClass="login-container">

    <padding>
        <Insets top="30" right="40" bottom="30" left="40"/>
    </padding>

    <!-- TÍTULO -->
    <Label text="StockMaster" styleClass="login-title"/>
    <Label text="Introduce tus credenciales" styleClass="login-subtitle"/>

    <Region prefHeight="10"/>

    <!-- EMAIL -->
    <Label text="Email" styleClass="login-label"/>
    <TextField fx:id="emailField"
               promptText="usuario@empresa.com"
               prefWidth="280"
               maxWidth="280"/>

    <!-- CONTRASEÑA -->
    <Label text="Contraseña" styleClass="login-label"/>
    <PasswordField fx:id="passwordField"
                   promptText="••••••••"
                   prefWidth="280"
                   maxWidth="280"/>

    <Region prefHeight="6"/>

    <!-- BOTÓN -->
    <Button fx:id="btnLogin"
            text="Iniciar sesión"
            prefWidth="280"
            maxWidth="280"
            onAction="#handleLogin"
            styleClass="login-btn"/>

    <!-- ERROR -->
    <Label fx:id="lblError"
           text=""
           styleClass="login-error"
           wrapText="true"
           maxWidth="280"/>
</VBox>