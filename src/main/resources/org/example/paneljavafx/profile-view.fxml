<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="org.example.paneljavafx.controller.ProfileController"
      spacing="20" styleClass="profile-root">

    <padding>
        <Insets top="24" right="24" bottom="24" left="24"/>
    </padding>

    <Label text="Perfil de Usuario"
           styleClass="cliente-panel-title"/>

    <Separator/>

    <!-- DATOS SIMPLES -->
    <GridPane hgap="16" vgap="12" styleClass="cp-data-card">
        <columnConstraints>
            <ColumnConstraints hgrow="NEVER" prefWidth="100"/>
            <ColumnConstraints hgrow="SOMETIMES"/>
        </columnConstraints>

        <!-- Nombre -->
        <Label text="Nombre:" GridPane.rowIndex="0" styleClass="cp-field-label"/>
        <Label fx:id="nameLabel" GridPane.columnIndex="1" GridPane.rowIndex="0" styleClass="cp-field-value"/>

        <!-- Email -->
        <Label text="Email:" GridPane.rowIndex="1" styleClass="cp-field-label"/>
        <Label fx:id="emailLabel" GridPane.columnIndex="1" GridPane.rowIndex="1" styleClass="cp-field-value"/>

        <!-- DNI -->
        <Label text="DNI:" GridPane.rowIndex="2" styleClass="cp-field-label"/>
        <Label fx:id="dniLabel" GridPane.columnIndex="1" GridPane.rowIndex="2" styleClass="cp-field-value"/>

        <!-- País -->
        <Label text="País:" GridPane.rowIndex="3" styleClass="cp-field-label"/>
        <Label fx:id="countryLabel" GridPane.columnIndex="1" GridPane.rowIndex="3" styleClass="cp-field-value"/>

        <!-- Fecha Alta -->
        <Label text="Alta:" GridPane.rowIndex="4" styleClass="cp-field-label"/>
        <Label fx:id="joinDateLabel" GridPane.columnIndex="1" GridPane.rowIndex="4" styleClass="cp-field-value"/>

        <!-- Rol -->
        <Label text="Rol:" GridPane.rowIndex="5" styleClass="cp-field-label"/>
        <Label fx:id="roleLabel" GridPane.columnIndex="1" GridPane.rowIndex="5" styleClass="cp-field-value"/>
    </GridPane>
</VBox>