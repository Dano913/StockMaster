<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.chart.PieChart?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<StackPane stylesheets="@trading-theme.css"
           xmlns="http://javafx.com/javafx/25"
           xmlns:fx="http://javafx.com/fxml/1"
           fx:controller="org.example.paneljavafx.controller.CarteraGestorAdminViewController">

    <children>

        <AnchorPane AnchorPane.topAnchor="0"
                    AnchorPane.bottomAnchor="0"
                    AnchorPane.leftAnchor="0"
                    AnchorPane.rightAnchor="0">

            <children>

                <VBox spacing="12"
                      styleClass="cliente-left-panel"
                      AnchorPane.topAnchor="0"
                      AnchorPane.bottomAnchor="0"
                      AnchorPane.leftAnchor="0"
                      AnchorPane.rightAnchor="0">

                    <!-- HEADER -->
                    <HBox alignment="CENTER_LEFT" spacing="10">

                        <Label text="CLIENTES"
                               styleClass="cliente-panel-title"/>

                        <Region HBox.hgrow="ALWAYS"/>

                        <Button text="Añadir Cliente"
                                onAction="#openAddCliente"
                                styleClass="btn-primary"/>

                    </HBox>

                    <!-- KPIs -->
                    <HBox spacing="12">

                        <VBox style="-fx-padding: 12; -fx-background-color: #1b1f2a; -fx-background-radius: 8;"
                              HBox.hgrow="ALWAYS">

                            <Label text="WALLET TOTAL"
                                   style="-fx-text-fill: #9aa4b2; -fx-font-size: 11px;"/>

                            <Label fx:id="labelManagedWallet"
                                   text="€0.00"
                                   style="-fx-text-fill: #00d4ff; -fx-font-size: 18px; -fx-font-weight: bold;"/>
                        </VBox>

                        <VBox style="-fx-padding: 12; -fx-background-color: #1b1f2a; -fx-background-radius: 8;"
                              HBox.hgrow="ALWAYS">

                            <Label text="TOTAL CLIENTES"
                                   style="-fx-text-fill: #9aa4b2; -fx-font-size: 11px;"/>

                            <Label fx:id="labelTotalClientes"
                                   text="0"
                                   style="-fx-text-fill: #00d4ff; -fx-font-size: 18px; -fx-font-weight: bold;"/>
                        </VBox>

                    </HBox>

                    <!-- PIE CHART -->
                    <VBox spacing="8"
                          style="-fx-padding: 12; -fx-background-color: #141824; -fx-background-radius: 8;">

                        <Label text="DISTRIBUCIÓN"
                               style="-fx-text-fill: #9aa4b2; -fx-font-size: 11px;"/>

                        <PieChart fx:id="clientsPieChart"
                                  legendVisible="false"
                                  labelsVisible="true"
                                  VBox.vgrow="ALWAYS"/>
                    </VBox>

                    <!-- SEARCH -->
                    <TextField fx:id="searchField"
                               promptText="Buscar por nombre, email..."
                               styleClass="cliente-search"/>

                    <!-- TABLE -->
                    <TableView fx:id="clientsTable"
                               VBox.vgrow="ALWAYS"
                               styleClass="cliente-table">

                        <columnResizePolicy>
                            <TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/>
                        </columnResizePolicy>

                        <columns>
                            <TableColumn fx:id="colName" text="Nombre Completo"/>
                            <TableColumn fx:id="colEmail" text="Email"/>
                            <TableColumn fx:id="colActions" text="Acciones"/>
                        </columns>

                        <placeholder>
                            <Label text="Sin clientes"/>
                        </placeholder>

                    </TableView>

                </VBox>

            </children>

        </AnchorPane>

        <!-- OVERLAY -->
        <StackPane fx:id="overlayContainer"
                   visible="false"
                   managed="false"
                   alignment="CENTER"
                   style="-fx-background-color: rgba(0,0,0,0.4);"/>

    </children>

</StackPane>