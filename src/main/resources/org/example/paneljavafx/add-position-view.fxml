<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns="http://javafx.com/javafx/17"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="org.example.paneljavafx.controller.AddPositionController"
      spacing="18"
      prefWidth="500" prefHeight="300"
      minWidth="340" minHeight="240"
      maxWidth="600" maxHeight="400"
      alignment="CENTER"
      styleClass="modal-container">

    <padding>
        <Insets top="24" right="24" bottom="24" left="24"/>
    </padding>

    <!-- HEADER COMPACTO -->
    <VBox spacing="8" alignment="CENTER">
        <Label text="Nueva Posición" styleClass="modal-title"/>
        <Separator styleClass="modal-separator"/>
    </VBox>

    <!-- FORM COMPACTO -->
    <VBox spacing="14">

        <!-- FONDO -->
        <VBox spacing="4">
            <Label text="Fondo" styleClass="form-label"/>
            <ComboBox fx:id="fundCombo"
                      prefWidth="280"
                      styleClass="form-combo"
                      promptText="Selecciona fondo"/>
        </VBox>

        <!-- CANTIDAD -->
        <VBox spacing="4">
            <Label text="Cantidad" styleClass="form-label"/>
            <TextField fx:id="amountField"
                       prefWidth="280"
                       styleClass="form-field"
                       promptText="0.00"/>
        </VBox>

    </VBox>

    <!-- BOTONES COMPACTOS -->
    <HBox spacing="10" alignment="CENTER_RIGHT">
        <Region HBox.hgrow="ALWAYS"/>
        <Button text="Cancelar" onAction="#cancel" styleClass="btn-secondary" prefHeight="38"/>
        <Button fx:id="deleteButton" text="Eliminar" onAction="#sell" styleClass="btn-danger" prefHeight="38" visible="false" managed="false"/>
        <Button fx:id="saveBtn" text="Crear" onAction="#save" styleClass="btn-primary" prefHeight="38"/>
    </HBox>

</VBox>