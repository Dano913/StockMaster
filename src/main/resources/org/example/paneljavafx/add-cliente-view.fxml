<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns="http://javafx.com/javafx/17"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="org.example.paneljavafx.controller.AddClienteController"
      alignment="CENTER"
      spacing="15"
      styleClass="form-container"
      maxWidth="400"
      style="-fx-background-color: #1e1e1e; -fx-padding: 20; -fx-background-radius: 10;">

    <!-- 🔹 TÍTULO DINÁMICO -->
    <Label fx:id="titleLabel"
           text="Nuevo Cliente"
           style="-fx-font-size: 20px; -fx-text-fill: white;" />

    <!-- 🔹 FORMULARIO -->
    <GridPane hgap="10" vgap="10">

        <columnConstraints>
            <ColumnConstraints percentWidth="100"/>
        </columnConstraints>

        <children>

            <TextField fx:id="nombreField" promptText="Nombre" GridPane.rowIndex="0"/>
            <TextField fx:id="apellidoField" promptText="Apellido" GridPane.rowIndex="1"/>
            <TextField fx:id="emailField" promptText="Email" GridPane.rowIndex="2"/>
            <TextField fx:id="dniField" promptText="DNI" GridPane.rowIndex="3"/>
            <TextField fx:id="paisField" promptText="País" GridPane.rowIndex="4"/>

        </children>
    </GridPane>

    <!-- 🔹 BOTONES -->
    <HBox spacing="10" alignment="CENTER">

        <Button text="Guardar"
                onAction="#saveCliente"
                styleClass="btn-primary"/>

        <Button fx:id="deleteButton"
                text="Eliminar"
                onAction="#deleteCliente"
                styleClass="btn-danger"/>

        <Button text="Cancelar"
                onAction="#cancel"/>

    </HBox>

</VBox>