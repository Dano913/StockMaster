<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns="http://javafx.com/javafx/17"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="org.example.paneljavafx.controller.AddClienteController"

      alignment="CENTER"
      spacing="15"

      prefWidth="400"
      maxWidth="400"
      minWidth="300"

      styleClass="form-container"
      style="-fx-background-color: #1e1e1e;
             -fx-padding: 20;
             -fx-background-radius: 10;">

    <!-- ================= TITLE ================= -->
    <Label fx:id="titleLabel"
           text="Nuevo Cliente"
           wrapText="true"
           style="-fx-font-size: 20px; -fx-text-fill: white;" />

    <!-- ================= FORM ================= -->
    <GridPane hgap="10"
              vgap="10"
              maxWidth="Infinity">

        <columnConstraints>
            <ColumnConstraints hgrow="ALWAYS"/>
        </columnConstraints>

        <rowConstraints>
            <RowConstraints vgrow="NEVER"/>
            <RowConstraints vgrow="NEVER"/>
            <RowConstraints vgrow="NEVER"/>
            <RowConstraints vgrow="NEVER"/>
            <RowConstraints vgrow="NEVER"/>
        </rowConstraints>

        <children>

            <TextField fx:id="nombreField"
                       promptText="Nombre"
                       GridPane.rowIndex="0"
                       maxWidth="Infinity"/>

            <TextField fx:id="apellidoField"
                       promptText="Apellido"
                       GridPane.rowIndex="1"
                       maxWidth="Infinity"/>

            <TextField fx:id="emailField"
                       promptText="Email"
                       GridPane.rowIndex="2"
                       maxWidth="Infinity"/>

            <TextField fx:id="dniField"
                       promptText="DNI"
                       GridPane.rowIndex="3"
                       maxWidth="Infinity"/>

            <TextField fx:id="paisField"
                       promptText="País"
                       GridPane.rowIndex="4"
                       maxWidth="Infinity"/>

        </children>
    </GridPane>

    <!-- ================= BUTTONS ================= -->
    <HBox spacing="10" alignment="CENTER">

        <Button text="Guardar"
                onAction="#saveCliente"
                styleClass="btn-primary"/>

        <Button fx:id="deleteButton"
                text="Eliminar"
                onAction="#deleteCliente"
                styleClass="btn-danger"/>

        <Button text="Cancelar"
                onAction="#cancel"/>

    </HBox>

</VBox>