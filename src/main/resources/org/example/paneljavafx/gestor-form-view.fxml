<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns="http://javafx.com/javafx/17"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="org.example.paneljavafx.controller.GestorFormController"
      alignment="CENTER"
      spacing="15"
      maxWidth="450"
      style="
        -fx-background-color: #1e1e1e;
        -fx-padding: 20;
        -fx-background-radius: 10;
      ">

    <!-- ========================= -->
    <!-- TÍTULO DINÁMICO -->
    <!-- ========================= -->
    <Label fx:id="titleLabel"
           text="Nuevo Gestor"
           style="-fx-font-size: 20px; -fx-text-fill: white;" />

    <!-- ========================= -->
    <!-- FORM -->
    <!-- ========================= -->
    <GridPane hgap="10" vgap="10">

        <columnConstraints>
            <ColumnConstraints percentWidth="100"/>
        </columnConstraints>

        <children>

            <TextField fx:id="nombreField"
                       promptText="Nombre"
                       GridPane.rowIndex="0"/>

            <TextField fx:id="apellidosField"
                       promptText="Apellidos"
                       GridPane.rowIndex="1"/>

            <TextField fx:id="emailField"
                       promptText="Email"
                       GridPane.rowIndex="2"/>

            <TextField fx:id="dniField"
                       promptText="DNI"
                       GridPane.rowIndex="3"/>

            <TextField fx:id="telefonoField"
                       promptText="Teléfono"
                       GridPane.rowIndex="4"/>

            <TextField fx:id="experienciaField"
                       promptText="Años experiencia"
                       GridPane.rowIndex="5"/>

            <ComboBox fx:id="perfilRiesgoField"
                      promptText="Perfil de riesgo"
                      GridPane.rowIndex="6"/>

        </children>
    </GridPane>

    <!-- ========================= -->
    <!-- BOTONES -->
    <!-- ========================= -->
    <HBox spacing="10" alignment="CENTER">

        <Button text="Guardar"
                onAction="#save"
                styleClass="btn-primary"/>

        <Button fx:id="deleteButton"
                text="Eliminar"
                onAction="#delete"
                styleClass="btn-danger"/>

        <Button text="Cancelar"
                onAction="#cancel"
                styleClass="btn-secondary"/>

    </HBox>

</VBox>