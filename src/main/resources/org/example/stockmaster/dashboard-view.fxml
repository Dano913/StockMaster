<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="org.example.stockmaster.javafx.controller.DashboardController">

    <!-- TOP BAR -->
    <top>
        <ToolBar>
            <Label text="ADMIN PANEL - FUND MANAGEMENT" />
            <Pane HBox.hgrow="ALWAYS"/>
            <Button text="Logout"/>
        </ToolBar>
    </top>

    <!-- MAIN CONTENT -->
    <center>
        <TabPane tabClosingPolicy="UNAVAILABLE">

            <!-- DASHBOARD -->
            <Tab text="Dashboard">
                <VBox spacing="10" style="-fx-padding: 15;">
                    <Label text="Global Overview" style="-fx-font-size: 18px;"/>

                    <HBox spacing="20">
                        <Label text="Total Fund: $1,245,000"/>
                        <Label text="ROI: +12.4%"/>
                        <Label text="Risk: Medium"/>
                    </HBox>

                    <TableView fx:id="dashboardTable" prefHeight="400"/>
                </VBox>
            </Tab>

            <!-- PERFIL GESTOR -->
            <Tab text="Gestor">
                <GridPane hgap="10" vgap="10" style="-fx-padding: 15;">

                    <Label text="Nombre:" GridPane.rowIndex="0" GridPane.columnIndex="0"/>
                    <TextField fx:id="nameField" GridPane.rowIndex="0" GridPane.columnIndex="1"/>

                    <Label text="Email:" GridPane.rowIndex="1" GridPane.columnIndex="0"/>
                    <TextField fx:id="emailField" GridPane.rowIndex="1" GridPane.columnIndex="1"/>

                    <Label text="Estrategia:" GridPane.rowIndex="2" GridPane.columnIndex="0"/>
                    <TextArea fx:id="strategyArea" GridPane.rowIndex="2" GridPane.columnIndex="1"/>

                    <Button text="Guardar"
                            GridPane.rowIndex="3"
                            GridPane.columnIndex="1"/>
                </GridPane>
            </Tab>

            <!-- FONDO GLOBAL -->
            <Tab text="Fondo Global">
                <VBox spacing="10" style="-fx-padding: 15;">

                    <HBox spacing="10">
                        <Button text="Añadir Activo"/>
                        <Button text="Eliminar Activo"/>
                        <Button text="Rebalancear"/>
                    </HBox>

                    <TableView fx:id="fundTable" prefHeight="400"/>
                </VBox>
            </Tab>

            <!-- ACTIVOS -->
            <Tab text="Activos">
                <SplitPane orientation="HORIZONTAL">

                    <!-- LISTA DE ACTIVOS -->
                    <VBox spacing="10" style="-fx-padding: 10;">
                        <Label text="Activos"/>
                        <ListView fx:id="assetList"/>
                        <Button text="Nuevo Activo"/>
                    </VBox>

                    <!-- DETALLE DEL ACTIVO -->
                    <VBox spacing="10" style="-fx-padding: 10;">
                        <Label text="Detalle del Activo" style="-fx-font-size: 16px;"/>

                        <TextField fx:id="assetName" promptText="Nombre"/>
                        <TextField fx:id="assetPrice" promptText="Precio actual"/>

                        <Label text="Variables que afectan al precio"/>

                        <TableView fx:id="variablesTable" prefHeight="200"/>

                        <Button text="Añadir Variable"/>
                        <Button text="Guardar Cambios"/>
                    </VBox>

                </SplitPane>
            </Tab>

        </TabPane>
    </center>

</BorderPane>