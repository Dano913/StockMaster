<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<TabPane xmlns:fx="http://javafx.com/fxml"
         fx:controller="org.example.stockmaster.javafx.controller.AdminController"
         style="-fx-background-color: transparent;">

    <!-- ========================= -->
    <!-- TAB 1: TIME TRACKING      -->
    <!-- ========================= -->
    <!-- ========================= -->
    <!-- TAB 1: TIME TRACKING      -->
    <!-- ========================= -->
    <Tab text="Time Tracking" closable="false">
        <VBox style="-fx-background-color: transparent;">
            <HBox alignment="CENTER_RIGHT" style="-fx-padding: 10;">
                <Button text="Logout" onAction="#handleLogout" style="..."/>
            </HBox>

            <HBox spacing="10" prefHeight="500" maxHeight="500" minHeight="500"
                  style="-fx-padding: 10;">

                <VBox maxWidth="400" prefHeight="300" maxHeight="400" minHeight="500"
                      HBox.hgrow="NEVER"
                      style="-fx-background-color: transparent;">
                    <fx:include fx:id="profileContainer"
                                source="profile-user-view.fxml"
                                VBox.vgrow="ALWAYS"/>
                </VBox>

                <VBox fx:id="timeRecordContainer"
                      spacing="10"
                      alignment="TOP_CENTER"
                      prefHeight="500" maxHeight="500" minHeight="500"
                      HBox.hgrow="ALWAYS"
                      style="-fx-padding: 10;"/>
            </HBox>
        </VBox>
    </Tab>

    <!-- ========================= -->
    <!-- TAB 2: USERS              -->
    <!-- ========================= -->
    <Tab text="Users" closable="false">
        <VBox spacing="15" alignment="TOP_CENTER"
              style="-fx-padding: 20; -fx-background-color: transparent;">
            <HBox spacing="10" alignment="CENTER"
                  style="
                  -fx-padding: 10;
                  -fx-background-color: rgba(255,255,255,0.60);
                  -fx-background-radius: 14;
                  -fx-border-radius: 14;
                  -fx-border-color: rgba(255,255,255,0.6);
                  -fx-border-width: 1;
                  -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.15), 10, 0.2, 0, 2);">

                <TextField fx:id="searchField"
                           onAction="#handleClearSearch"
                           promptText="Search users or records..."
                           HBox.hgrow="ALWAYS"
                           maxWidth="600"
                           style="
                           -fx-background-color: rgba(255,255,255,0.5);
                           -fx-background-radius: 8;
                           -fx-padding: 8;"/>
            </HBox>

            <HBox spacing="20" alignment="CENTER" VBox.vgrow="ALWAYS">

                <VBox spacing="8" HBox.hgrow="ALWAYS"
                      style="
                      -fx-background-color: rgba(255,255,255,0.60);
                      -fx-padding: 15;
                      -fx-background-radius: 20;
                      -fx-border-radius: 20;
                      -fx-border-color: rgba(255,255,255,0.6);
                      -fx-border-width: 1;
                      -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.25), 20, 0.3, 0, 4);">

                    <Label text="👤 Users"
                           style="-fx-font-size: 16px; -fx-font-weight: bold;"/>
                    <Separator/>
                    <TableView fx:id="usersTable" VBox.vgrow="ALWAYS"
                               style="-fx-background-color: transparent; -fx-background-radius: 10;">
                        <columns>
                            <TableColumn fx:id="colName" text="Name"/>
                            <TableColumn fx:id="colEmail" text="Email"/>
                            <TableColumn fx:id="colAge" text="Age"/>
                            <TableColumn fx:id="colPhone" text="Phone"/>
                            <TableColumn fx:id="colDni" text="DNI"/>
                        </columns>
                    </TableView>
                </VBox>

                <VBox spacing="8" HBox.hgrow="ALWAYS"
                      style="
                      -fx-background-color: rgba(255,255,255,0.60);
                      -fx-padding: 15;
                      -fx-background-radius: 20;
                      -fx-border-radius: 20;
                      -fx-border-color: rgba(255,255,255,0.6);
                      -fx-border-width: 1;
                      -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.25), 20, 0.3, 0, 4);">

                    <Label text="⏱ Time Records"
                           style="-fx-font-size: 16px; -fx-font-weight: bold;"/>
                    <Separator/>
                    <TableView fx:id="timeRecordsTable" VBox.vgrow="ALWAYS"
                               style="-fx-background-color: transparent; -fx-background-radius: 10;">
                        <columns>
                            <TableColumn fx:id="colUser" text="User"/>
                            <TableColumn fx:id="colDateTime" text="Date"/>
                            <TableColumn fx:id="colType" text="Type"/>
                        </columns>
                    </TableView>
                </VBox>

            </HBox>
        </VBox>
    </Tab>

    <!-- ========================= -->
    <!-- TAB 3: REGISTER USER      -->
    <!-- ========================= -->
    <Tab text="Register User" closable="false">
        <VBox spacing="12" alignment="TOP_CENTER"
              maxWidth="Infinity" maxHeight="Infinity"
              style="-fx-padding: 30; -fx-background-color: transparent;">

            <Label text="Register User"
                   style="-fx-font-size: 20px; -fx-font-weight: bold;"/>
            <Separator/>

            <VBox spacing="10" maxWidth="500" alignment="TOP_CENTER"
                  style="
                  -fx-background-color: rgba(255,255,255,0.60);
                  -fx-padding: 25;
                  -fx-background-radius: 20;
                  -fx-border-radius: 20;
                  -fx-border-color: rgba(255,255,255,0.6);
                  -fx-border-width: 1;
                  -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.25), 20, 0.3, 0, 4);">

                <TextField fx:id="nameField" promptText="Name"
                           maxWidth="Infinity"
                           style="-fx-background-color: rgba(255,255,255,0.5); -fx-background-radius: 8; -fx-padding: 8;"/>

                <TextField fx:id="emailField" promptText="Email"
                           maxWidth="Infinity"
                           style="-fx-background-color: rgba(255,255,255,0.5); -fx-background-radius: 8; -fx-padding: 8;"/>

                <TextField fx:id="dniField" promptText="DNI"
                           maxWidth="Infinity"
                           style="-fx-background-color: rgba(255,255,255,0.5); -fx-background-radius: 8; -fx-padding: 8;"/>


                <TextField fx:id="ageField" promptText="Age"
                           maxWidth="Infinity"
                           style="-fx-background-color: rgba(255,255,255,0.5); -fx-background-radius: 8; -fx-padding: 8;"/>

                <TextField fx:id="genderField" promptText="Gender"
                           maxWidth="Infinity"
                           style="-fx-background-color: rgba(255,255,255,0.5); -fx-background-radius: 8; -fx-padding: 8;"/>

                <TextField fx:id="phoneField" promptText="Phone"
                           maxWidth="Infinity"
                           style="-fx-background-color: rgba(255,255,255,0.5); -fx-background-radius: 8; -fx-padding: 8;"/>

                <PasswordField fx:id="passwordField" promptText="Password"
                               maxWidth="Infinity"
                               style="-fx-background-color: rgba(255,255,255,0.5); -fx-background-radius: 8; -fx-padding: 8;"/>

                <ComboBox fx:id="roleBox" promptText="Role"
                          maxWidth="Infinity"
                          style="-fx-background-color: rgba(255,255,255,0.5); -fx-background-radius: 8;"/>

                <Button text="Register User"
                        onAction="#handleRegisterUser"
                        maxWidth="Infinity"
                        style="
                        -fx-background-color: rgba(255,255,255,0.60);
                        -fx-background-radius: 10;
                        -fx-border-radius: 10;
                        -fx-border-color: rgba(255,255,255,0.6);
                        -fx-border-width: 1;
                        -fx-padding: 10;
                        -fx-font-weight: bold;
                        -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.15), 10, 0.2, 0, 2);"/>

                <Label fx:id="registerStatus"
                       style="-fx-font-weight: bold;"/>

            </VBox>
        </VBox>
    </Tab>

</TabPane>